rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      // In a real app, I'd check a dedicated 'admins' collection or a 'role' field in the user doc.
      // Since I don't have custom claims, I'll check the user's role in the /users collection.
      // But rules can't easily check 'this' user's role without a get().
      // Using get() in every rule is expensive/slow for list.
      // Strategy: for admin operations, use get() to check /users/$(request.auth.uid).data.role == 'admin'
      return isSignedIn() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- Entity Validations ---

    function isValidUser(data) {
      return data.keys().hasAll(['id', 'name', 'username', 'role', 'status']) &&
             data.id is string && data.id.size() <= 128 &&
             data.name is string && data.name.size() <= 200 &&
             data.username is string && data.username.size() <= 100 &&
             data.role in ['admin', 'reader'] &&
             data.status in ['active', 'pending', 'suspended'];
    }

    function isValidBook(data) {
      return data.keys().hasAll(['id', 'title', 'author', 'category', 'status', 'bookCode']) &&
             data.id is string &&
             data.title is string && data.title.size() <= 200 &&
             data.author is string && data.author.size() <= 200 &&
             data.status in ['Available', 'Issued', 'Lost'];
    }

    // --- Rules ---

    match /users/{userId} {
      allow read: if isSignedIn(); // Users can see profiles, or we restrict to self/admin if PII exists
      allow create: if isSignedIn() && isValidUser(incoming()) && (incoming().id == request.auth.uid || isAdmin());
      allow update: if isSignedIn() && isValidUser(incoming()) && (isOwner(userId) || isAdmin()) &&
                    incoming().role == existing().role; // Users can't change their own role
      allow delete: if isAdmin();
    }

    match /books/{bookId} {
      allow read: if true; // Publicly viewable
      allow write: if isAdmin() && isValidBook(incoming());
    }

    match /issues/{issueId} {
      allow read: if isSignedIn(); // Members see their issues, admin sees all
      allow create: if isSignedIn() && (incoming().userId == request.auth.uid || isAdmin());
      allow update, delete: if isAdmin();
    }

    match /donations/{donationId} {
      allow read: if isAdmin();
      allow create: if true; // Public can donate
      allow update: if isAdmin();
    }

    match /finances/{financeId} {
      allow read, write: if isAdmin();
    }

    match /team/{memberId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /posts/{postId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /messages/{messageId} {
      allow create: if true;
      allow read, write: if isAdmin();
    }
  }
}
